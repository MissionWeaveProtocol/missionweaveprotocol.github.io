        "Coordinator verifizieren Evidence und Artifact, bevor ein Mensch die abgeschlossene Mission genehmigt.",
      ],
    ],
    panel: {
      eyebrow: "Eine Mission, ein Group",
      title: "Vom Ziel zum genehmigten Ergebnis",
      badge: "Entwurf 0.1",
      aria: "Mission-Lebenszyklus",
      steps: [
        [
          "MissionOwner",
          "Definiert Erfolg",
          "Ziel, Grenzen, Budget, Frist und finale Approval.",
        ],
        [
          "Coordinator",
          "Plant und weist zu",
          "WorkItem gelangen durch ausdrückliche Angebote und Annahme zu geeigneten Agent.",
        ],
        [
          "Worker",
          "Kooperieren und führen aus",
          "Peers tauschen Kontext aus, halten Lease und veröffentlichen unveränderliche Artifact.",
        ],
        [
          "Prüfung",
          "Verifizieren, dann genehmigen",
          "Der Coordinator prüft Evidence; der Mensch akzeptiert das genaue Ergebnis.",
        ],
      ],
    },
    scheduler: {
      eyebrow: "Viele Group, ein Worker",
      title: "Koordination endet an der Group-Grenze. Planung nicht.",
      body: "Ein Coordinator verantwortet den Fortschritt innerhalb seiner Mission. Ein Worker kann vielen Mission angehören; daher entscheidet sein eigener Scheduler anhand Group-spezifischer Warteschlangen, Capacity Slot, Fristen, Abhängigkeiten und lokaler Richtlinien, was als Nächstes ausgeführt wird.",
      aria: "Group-spezifische Warteschlangen speisen einen Worker Scheduler und isolierte Capacity Slot",
      queues: "Group-spezifische Warteschlangen",
      owned: "Im Besitz des Worker",
      scheduler: "Scheduler",
      policy: "Priorität · Bereitschaft · Richtlinie",
      slots: "Capacity Slot",
      running: "aktiv",
      ready: "bereit",
    },
    boundaries: [
      [
        "Für Organization entwickelt",
        "Gemeinsames Vertrauen, ausdrückliche Autorität.",
        "Die Organization kontrolliert Agent-Identität, Richtlinien, Autorisierung und dauerhafte Group-Reihenfolge. Agent bleiben in Conversation Peers, während folgenreiche Zustandsänderungen strukturiert, signiert, begrenzt und auditierbar bleiben.",
      ],
      [
        "Bewusst außerhalb des Umfangs",
        "Kein weiteres Agent RPC.",
        "MissionWeaveProtocol definiert weder Modell-Prompts, physisches Peer-to-Peer-Routing, organisationsübergreifende Föderation noch verteilten Konsens. Es definiert, wie eine Organization komplexe Arbeit von Agent sicher abschließt.",
      ],
    ],
    closing: {
      eyebrow: "Mit dem Entwurf beginnen",
      title: "Zusammenarbeit um Arbeit aufbauen, nicht nur um Message.",
      link: "Mit MissionWeaveProtocol 0.1 beginnen",
    },
  },
};
const copy = copies[locale];
---

<section class="home-story" aria-labelledby="missionweaveprotocol-story">
  <div class="intro-block">
    <p class="eyebrow">{copy.intro.eyebrow}</p>
    <h2 id="missionweaveprotocol-story">{copy.intro.title}</h2>
    <p class="section-lede">{copy.intro.body}</p>
  </div>

  <div class="principle-grid">
    {
      copy.principles.map(([title, body], index) => (
        <article>
          <span class="principle-number">
            {String(index + 1).padStart(2, "0")}
          </span>
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))
    }
  </div>

  <div class="story-panel">
    <div class="panel-heading">
      <div>
        <p class="eyebrow">{copy.panel.eyebrow}</p>
        <h2>{copy.panel.title}</h2>
      </div>
      <span class="draft-badge">{copy.panel.badge}</span>
    </div>

    <ol class="mission-flow" aria-label={copy.panel.aria}>
      {
        copy.panel.steps.map(([role, title, body], index) => (
          <li>
            <span class="step-number">{index + 1}</span>
            <small>{role}</small>
            <strong>{title}</strong>
            <p>{body}</p>
          </li>
        ))
      }
    </ol>
  </div>

  <div class="scheduler-section">
    <div class="scheduler-copy">
      <p class="eyebrow">{copy.scheduler.eyebrow}</p>
      <h2>{copy.scheduler.title}</h2>
      <p>{copy.scheduler.body}</p>
    </div>

    <div class="scheduler-diagram" role="img" aria-label={copy.scheduler.aria}>
      <div class="queue-column">
        <span class="diagram-label">{copy.scheduler.queues}</span>
        <div class="queue-row">
          <span>Group Atlas</span><i></i><i></i><i class="muted"></i>
        </div>
        <div class="queue-row">
          <span>Group Beacon</span><i></i><i class="muted"></i>
        </div>
        <div class="queue-row">
          <span>Group Cedar</span><i></i><i></i>
        </div>
      </div>

      <div class="diagram-arrow" aria-hidden="true">→</div>

      <div class="scheduler-core">
        <small>{copy.scheduler.owned}</small>
        <strong>{copy.scheduler.scheduler}</strong>
        <p>{copy.scheduler.policy}</p>
      </div>

      <div class="diagram-arrow" aria-hidden="true">→</div>

      <div class="slot-column">
        <span class="diagram-label">{copy.scheduler.slots}</span>
        <div class="slot">01 <span>{copy.scheduler.running}</span></div>
        <div class="slot">02 <span>{copy.scheduler.ready}</span></div>
      </div>
    </div>
  </div>

  <div class="boundary-grid">
    {
      copy.boundaries.map(([eyebrow, title, body], index) => (
        <article class:list={["boundary-card", { emphasis: index === 0 }]}>
          <p class="eyebrow">{eyebrow}</p>
          <h2>{title}</h2>
          <p>{body}</p>
        </article>
      ))
    }
  </div>

  <div class="closing-callout">
    <div>
      <p class="eyebrow">{copy.closing.eyebrow}</p>
      <h2>{copy.closing.title}</h2>
    </div>
    <a href={docsUrl}>
      {copy.closing.link}
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  .home-story {
    display: grid;
    gap: clamp(5rem, 10vw, 9rem);
    padding-block: 2rem 7rem;
  }

  .intro-block {
    max-width: 52rem;
  }

  .eyebrow {
    margin: 0 0 0.9rem;
    color: var(--sl-color-accent);
    font-size: 0.76rem;
    font-weight: 760;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    color: var(--sl-color-white);
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 1.08;
    letter-spacing: -0.045em;
  }

  .section-lede,
  .scheduler-copy > p:last-child,
  .boundary-card > p:last-child {
    margin: 1.5rem 0 0;
    color: var(--sl-color-gray-2);
    font-size: clamp(1rem, 1.8vw, 1.18rem);
    line-height: 1.75;
  }

  .principle-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.2rem;
    background: var(--sl-color-gray-5);
  }

  .principle-grid article {
    min-height: 15rem;
    padding: 1.5rem;
    background: var(--sl-color-bg);
  }

  .principle-number {
    display: inline-grid;
    width: 2.25rem;
    height: 2.25rem;
    place-items: center;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 50%;
    color: var(--sl-color-accent);
    font-size: 0.72rem;
    font-weight: 760;
  }

  .principle-grid h3 {
    margin: 2.8rem 0 0.7rem;
    font-size: 1.13rem;
    letter-spacing: -0.02em;
  }

  .principle-grid p {
    margin: 0;
    color: var(--sl-color-gray-2);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .story-panel {
    padding: clamp(1.5rem, 4vw, 3.5rem);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.6rem;
    background: color-mix(
      in srgb,
      var(--sl-color-gray-6) 35%,
      var(--sl-color-bg)
    );
  }

  .panel-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
  }

  .panel-heading h2 {
    font-size: clamp(1.8rem, 3vw, 2.7rem);
  }

  .draft-badge {
    flex: none;
    padding: 0.45rem 0.72rem;
    border: 1px solid
      color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
    border-radius: 999px;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    font-size: 0.72rem;
    font-weight: 720;
  }

  .mission-flow {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin: 3.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .mission-flow li {
    position: relative;
    min-height: 14rem;
    padding: 1.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    background: var(--sl-color-bg);
  }

  .mission-flow li:not(:last-child)::after {
    position: absolute;
    z-index: 2;
    top: 2rem;
    right: -1.56rem;
    width: 2.1rem;
    color: var(--sl-color-accent);
    background: var(--sl-color-bg);
    content: "→";
    font-weight: 800;
    text-align: center;
  }

  .step-number {
    display: block;
    margin-bottom: 2.5rem;
    color: var(--sl-color-accent);
    font-size: 0.8rem;
    font-weight: 760;
  }

  .mission-flow small {
    display: block;
    color: var(--sl-color-gray-3);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mission-flow strong {
    display: block;
    margin-top: 0.35rem;
    font-size: 1.05rem;
  }

  .mission-flow p {
    margin: 0.8rem 0 0;
    color: var(--sl-color-gray-2);
    font-size: 0.86rem;
    line-height: 1.55;
  }

  .scheduler-section {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(32rem, 1.22fr);
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: center;
  }

  .scheduler-copy h2 {
    font-size: clamp(2rem, 3.5vw, 3.15rem);
  }

  .scheduler-diagram {
    display: grid;
    grid-template-columns: 1fr auto 0.8fr auto 0.75fr;
    gap: 1rem;
    align-items: center;
    padding: clamp(1.2rem, 3vw, 2rem);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.5rem;
    background: color-mix(
      in srgb,
      var(--sl-color-gray-6) 38%,
      var(--sl-color-bg)
    );
  }

  .diagram-label {
    display: block;
    margin-bottom: 0.8rem;
    color: var(--sl-color-gray-3);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .queue-row {
    display: grid;
    grid-template-columns: 1fr repeat(3, 0.6rem);
    gap: 0.28rem;
    align-items: center;
    margin-top: 0.45rem;
    padding: 0.68rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.65rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-gray-2);
    font-size: 0.72rem;
  }

  .queue-row i {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 0.15rem;
    background: var(--sl-color-accent);
  }

  .queue-row i.muted {
    background: var(--sl-color-gray-5);
  }

  .diagram-arrow {
    color: var(--sl-color-accent);
    font-weight: 800;
  }

  .scheduler-core {
    padding: 1.25rem 0.9rem;
    border-radius: 1rem;
    background: #121826;
    color: #fff;
    text-align: center;
    box-shadow: 0 18px 36px rgba(18, 24, 38, 0.15);
  }

  .scheduler-core small,
  .scheduler-core strong {
    display: block;
  }

  .scheduler-core small {
    color: #aeb8ca;
    font-size: 0.65rem;
  }

  .scheduler-core strong {
    margin-top: 0.2rem;
    font-size: 1rem;
  }

  .scheduler-core p {
    margin: 0.65rem 0 0;
    color: #aeb8ca;
    font-size: 0.58rem;
  }

  .slot {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.45rem;
    padding: 0.65rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.65rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-accent);
    font-size: 0.72rem;
    font-weight: 740;
  }

  .slot span {
    color: var(--sl-color-gray-3);
    font-size: 0.62rem;
    font-weight: 500;
  }

  .boundary-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .boundary-card {
    min-height: 22rem;
    padding: clamp(1.5rem, 4vw, 3rem);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.4rem;
    background: var(--sl-color-bg);
  }

  .boundary-card.emphasis {
    border-color: #121826;
    background: #121826;
  }

  .boundary-card h2 {
    max-width: 12ch;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
  }

  .boundary-card.emphasis h2 {
    color: #fff;
  }

  .boundary-card.emphasis > p:last-child {
    color: #bbc3d1;
  }

  .closing-callout {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: clamp(1.5rem, 5vw, 3.5rem);
    border: 1px solid
      color-mix(in srgb, var(--sl-color-accent) 32%, var(--sl-color-gray-5));
    border-radius: 1.4rem;
    background: var(--sl-color-accent-low);
  }

  .closing-callout h2 {
    max-width: 16ch;
    color: var(--sl-color-accent-high);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
  }

  .closing-callout a {
    flex: none;
    padding: 0.85rem 1.05rem;
    border-radius: 0.65rem;
    background: var(--sl-color-accent);
    color: #fff;
    font-size: 0.88rem;
    font-weight: 720;
    text-decoration: none;
  }

  @media (max-width: 68rem) {
    .principle-grid,
    .mission-flow {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .mission-flow li:nth-child(2)::after {
      display: none;
    }

    .scheduler-section {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 42rem) {
    .home-story {
      gap: 4.5rem;
      padding-bottom: 4rem;
    }

    .principle-grid,
    .mission-flow,
    .boundary-grid {
      grid-template-columns: 1fr;
    }

    .principle-grid article,
    .mission-flow li,
    .boundary-card {
      min-height: auto;
    }

    .principle-grid h3 {
      margin-top: 1.8rem;
    }

    .mission-flow li::after {
      display: none;
    }

    .scheduler-diagram {
      grid-template-columns: 1fr;
    }

    .diagram-arrow {
      transform: rotate(90deg);
      text-align: center;
    }

    .closing-callout {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
